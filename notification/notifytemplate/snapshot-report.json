Subject: {{.EventArgs.OverallStatus}} on {{.Hostname}}

{{ $snapshots := .EventArgs.Snapshots | sortSnapshotManifestsByName }}{
  "status": {{ printf "%q" .EventArgs.OverallStatus }},
  "hostname": {{ printf "%q" .Hostname }},
  "generatedAt": {{ .EventTime | formatTime | printf "%q" }},
  "kopiaVersion": {{ printf "%q" .KopiaBuildVersion }},
  "snapshots": [
{{ range $i, $s := $snapshots }}{{ if $i }},
{{ end }}    {
      "id": {{ printf "%q" $s.Manifest.ID }},
      "path": {{ printf "%q" $s.Manifest.Source.Path }},
      "status": {{ printf "%q" $s.StatusCode }},
      "start": {{ $s.StartTimestamp | formatTime | printf "%q" }},
      "duration": {{ printf "%q" $s.Duration }},
      "totalSize": {{ $s.TotalSize }},
      "totalSizeDelta": {{ $s.TotalSizeDelta }},
      "totalFiles": {{ $s.TotalFiles }},
      "totalFilesDelta": {{ $s.TotalFilesDelta }},
      "totalDirs": {{ $s.TotalDirs }},
      "totalDirsDelta": {{ $s.TotalDirsDelta }}{{ if $s.Error }},
      "error": {{ printf "%q" $s.Error }}{{ end }}{{ if and $s.Manifest.RootEntry $s.Manifest.RootEntry.DirSummary $s.Manifest.RootEntry.DirSummary.FailedEntries }},
      "failedEntries": [
{{ range $j, $f := $s.Manifest.RootEntry.DirSummary.FailedEntries }}{{ if $j }},
{{ end }}        { "path": {{ printf "%q" $f.EntryPath }}, "error": {{ printf "%q" $f.Error }} }
{{- end }}
      ]
{{- end }}
    }
{{- end }}
  ]
}
